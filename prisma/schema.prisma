generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  decks        Deck[]
  comments     Comment[]

  // Team relationships
  ownedHubs    Hub[]    @relation("HubOwner")
  hubMemberships HubMember[]

  // Replay-review feature
  ownedPrimers    Primer[]
  uploadedReplays Replay[]
  authoredReviews Review[]

  // Playtest tracking
  loggedPlaytestGames PlaytestGame[]

  // Events (M4)
  createdEvents Event[]

  // Team Hub shared write-ups (M1)
  authoredReports MetaReport[]

  // Team Hub practices + event attendance (M1)
  createdPractices Practice[]
  practiceRsvps    PracticeRsvp[]
  eventAttendance  EventAttendance[]

  // Tournament submissions (legacy, reconciled)
  tournaments Tournament[]
}

model Deck {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Untitled Deck")
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments  Comment[]
  playtestGames PlaytestGame[]

  @@index([userId])
}

model Hub {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation("HubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     HubMember[]

  // Replay-review feature
  primers     Primer[]
  replays     Replay[]
  reviews     Review[]

  // Playtest tracking
  playtestGames PlaytestGame[]

  // Discord bridge + events (M4)
  discordWebhookUrl String?
  events            Event[]

  // Team Hub shared write-ups (M1)
  metaReports       MetaReport[]

  // Team Hub practices (M1)
  practices         Practice[]

  // Self-serve AI budget guard (M3). null/<=0 = unlimited.
  llmMonthlyTokenBudget Int?       @default(500000)
  llmUsage              LlmUsage[]

  // Tournament result sync (M5)
  tournamentResults TournamentResult[]

  @@index([inviteCode])
  @@index([ownerId])
}

model HubMember {
  id       String   @id @default(uuid())
  hubId    String
  userId   String
  joinedAt DateTime @default(now())

  // Team-hub profile: who this person is and what they play (Team Hub M0).
  // All optional so existing rows need no backfill.
  displayName String?
  petDecks    Json     @default("[]") // archetypes this person plays, e.g. ["Blurple Control"]
  pilots      Json     @default("[]") // archetypes they're strong with
  notes       String?  @db.Text

  hub       Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hubId, userId])
  @@index([hubId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  deckId    String
  userId    String
  createdAt DateTime @default(now())

  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Replay Review + Strategy Primers (coaching feature)
// Everything is scoped to a Hub so reviews/primers are team-shared.
// ---------------------------------------------------------------------------

model Primer {
  id            String   @id @default(uuid())
  hubId         String
  deckArchetype String                       // e.g. "Blurple Control"
  vsArchetype   String                       // e.g. "Go-Wide Dogs"
  verdict       String?                      // Favored / Even / Behind
  confidence    String   @default("Draft")   // Draft / Tentative / Solid
  gameplan      String?  @db.Text
  mustKill      String?  @db.Text
  mistakes      String?  @db.Text
  keyCards      Json     @default("[]")       // [{id,name,note}]
  ownerId       String?
  lastReviewedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hub     Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)
  owner   User?    @relation(fields: [ownerId], references: [id])
  reviews Review[]

  @@unique([hubId, deckArchetype, vsArchetype])
  @@index([hubId])
}

model Replay {
  id            String   @id @default(uuid())
  hubId         String
  uploaderId    String
  source        String                        // duels.ink | lorcanito | paper
  matchId       String?
  format        String?                       // Core / Infinity
  playerName    String?
  opponentName  String?
  matchResult   String?                       // W / L
  matchScore    String?                       // "0-2"
  parsed        Json     @default("{}")        // normalized summary (see Phase 3)
  createdAt     DateTime @default(now())

  hub      Hub      @relation(fields: [hubId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id])
  reviews  Review[]

  @@index([hubId])
}

model Review {
  id            String   @id @default(uuid())
  hubId         String
  replayId      String?                        // null for paper games w/o file
  primerId      String?
  authorId      String?                        // user who triggered it
  generatedBy   String   @default("llm")       // llm | agent | human
  gameNumber    Int?                           // which game in a BO3
  player        String?
  deckArchetype String?
  vsArchetype   String?
  result        String?                        // W / L
  recap         String   @db.Text              // flow recap
  lines         Json     @default("[]")         // [{turn, whatHappened, betterLine, why}]
  leakTags      String[]                        // ["over-traded","target selection"]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hub    Hub     @relation(fields: [hubId], references: [id], onDelete: Cascade)
  replay Replay? @relation(fields: [replayId], references: [id], onDelete: SetNull)
  primer Primer? @relation(fields: [primerId], references: [id], onDelete: SetNull)
  author User?   @relation(fields: [authorId], references: [id])

  @@index([hubId])
  @@index([replayId])
}

// ---------------------------------------------------------------------------
// Playtest & Matchup tracking (M1)
// A hub-shared log of practice games that rolls up into win-rate by matchup.
// ---------------------------------------------------------------------------

model PlaytestGame {
  id            String   @id @default(uuid())
  hubId         String
  loggedById    String                          // user who recorded the game
  deckId        String?                          // link to a saved Deck when chosen
  deckArchetype String                           // label/fallback, e.g. "Blurple Control"
  vsArchetype   String                           // opponent archetype
  result        String                           // "W" | "L"
  onPlay        Boolean?                          // true = on the play, false = on the draw
  format        String?                          // "Core" | "Infinity"
  lesson        String?  @db.Text                // optional takeaway
  playedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  hub      Hub   @relation(fields: [hubId], references: [id], onDelete: Cascade)
  loggedBy User  @relation(fields: [loggedById], references: [id])
  deck     Deck? @relation(fields: [deckId], references: [id], onDelete: SetNull)

  @@index([hubId])
  @@index([hubId, deckArchetype, vsArchetype])
}

// ---------------------------------------------------------------------------
// Events (M4) — team calendar (tournaments, playtest sessions, etc.)
// ---------------------------------------------------------------------------

model Event {
  id          String   @id @default(uuid())
  hubId       String
  createdById String
  title       String
  startsAt    DateTime
  location    String?
  kind        String?                          // "Tournament" | "Playtest" | "Other"
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  hub        Hub               @relation(fields: [hubId], references: [id], onDelete: Cascade)
  createdBy  User              @relation(fields: [createdById], references: [id])
  attendance EventAttendance[]

  @@index([hubId])
  @@index([hubId, startsAt])
}

// ---------------------------------------------------------------------------
// Team Hub practices (M1) — scrim/testing sessions anyone can post & RSVP to.
// ---------------------------------------------------------------------------

model Practice {
  id          String   @id @default(uuid())
  hubId       String
  createdById String
  title       String
  startsAt    DateTime?
  focus       String?  @db.Text             // what we're testing this session
  createdAt   DateTime @default(now())

  hub       Hub            @relation(fields: [hubId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
  rsvps     PracticeRsvp[]

  @@index([hubId])
  @@index([hubId, startsAt])
}

model PracticeRsvp {
  id         String @id @default(uuid())
  practiceId String
  memberId   String                          // userId of the responder
  status     String @default("yes")          // yes | no | maybe

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  member   User     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([practiceId, memberId])
  @@index([practiceId])
}

// ---------------------------------------------------------------------------
// Team Hub event attendance (M1) — who's going and what they're bringing.
// ---------------------------------------------------------------------------

model EventAttendance {
  id       String  @id @default(uuid())
  eventId  String
  memberId String                            // userId of the attendee
  going    Boolean @default(true)
  bringing String?                           // deck they'll play

  event  Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member User  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
}

// ---------------------------------------------------------------------------
// Meta reports (Team Hub M1) — shareable write-ups: meta reads, tech choices,
// tournament reports. Body is markdown. Any member can post/edit/read.
// ---------------------------------------------------------------------------

model MetaReport {
  id        String   @id @default(uuid())
  hubId     String
  authorId  String
  title     String
  body      String   @db.Text                 // markdown
  tags      String[]                           // e.g. ["meta", "matchup", "event-report"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hub    Hub  @relation(fields: [hubId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([hubId])
  @@index([hubId, createdAt])
}

// ---------------------------------------------------------------------------
// LLM usage ledger (M3) — one row per AI review generation, summed per month
// to enforce a hub's token budget.
// ---------------------------------------------------------------------------

model LlmUsage {
  id           String   @id @default(uuid())
  hubId        String
  userId       String?
  kind         String                          // "generate" | "regenerate"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())

  hub Hub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@index([hubId, createdAt])
}

// ---------------------------------------------------------------------------
// Tournament result sync (M5) — normalized results from PlayHub / Melee /
// manual / image import. Deduped per hub by (source, externalId).
// ---------------------------------------------------------------------------

model TournamentResult {
  id            String    @id @default(uuid())
  hubId         String
  addedById     String?
  source        String                          // "playhub" | "melee" | "manual" | "image"
  externalId    String?                         // id in the source system, for dedupe
  eventName     String
  eventDate     DateTime?
  playerName    String?
  deckArchetype String?
  placement     Int?
  record        String?                         // e.g. "5-1"
  createdAt     DateTime  @default(now())

  hub Hub @relation(fields: [hubId], references: [id], onDelete: Cascade)

  @@unique([hubId, source, externalId])
  @@index([hubId, eventDate])
}

// ---------------------------------------------------------------------------
// Tournament submissions (legacy — created outside Prisma via the standings/
// raw-DDL path). Reconciled into the schema so `prisma db push` no longer
// proposes dropping them. Field shapes mirror the live DB exactly.
// ---------------------------------------------------------------------------

model Tournament {
  id              String    @id @default(uuid())
  name            String
  organizerId     String
  submitCode      String    @unique
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  location        String?
  format          String?
  maxPlayers      Int?
  status          String    @default("open")
  requireApproval Boolean   @default(true)
  allowAnonymous  Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  casterCode      String?   @unique

  organizer   User         @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([casterCode])
  @@index([organizerId])
  @@index([status])
  @@index([submitCode])
}

model Submission {
  id                 String   @id @default(uuid())
  tournamentId       String
  playerName         String?
  playerEmail        String?
  playerId           String?
  deckName           String
  deckData           Json
  status             String   @default("pending")
  exportedToInkdecks Boolean  @default(false)
  inkdecksId         String?
  submittedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([submittedAt])
  @@index([tournamentId])
}
