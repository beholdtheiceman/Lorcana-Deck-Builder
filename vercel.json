{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@4.0.0"
    }
  },
  "rewrites": [
    { "source": "/((?!api/|@|src/|node_modules/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/hubs/digest", "schedule": "0 10 * * 1" }
  ]
}
