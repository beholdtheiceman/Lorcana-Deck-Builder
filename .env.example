# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
BCRYPT_COST=12

# AI (required for game reviews, report drafting, and meta Ask)
ANTHROPIC_API_KEY="sk-ant-..."

# Discord app (optional — only needed if using /api/discord/interactions)
DISCORD_PUBLIC_KEY=""

# Environment
NODE_ENV="development"
