# Database Configuration (Postgres connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Security
# Generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomUUID())"
JWT_SECRET="replace-with-a-long-random-secret"
BCRYPT_COST="12"

# Optional: Environment
NODE_ENV="development"

# Weekly Discord digest cron auth. REQUIRED in production — the /api/hubs/digest
# endpoint now fails closed (returns 401) if neither of these is set. Vercel
# auto-injects CRON_SECRET when configured; DIGEST_SECRET can be set manually.
# DIGEST_SECRET="replace-with-a-long-random-secret"
# CRON_SECRET="set-by-vercel-or-manually"

# Dev-only auto-login. Both NODE_ENV=development AND this flag must be set for
# getSession to auto-authenticate as DEV_USER_EMAIL. Never set in prod/preview.
# ALLOW_DEV_AUTH_BYPASS="true"
# DEV_USER_EMAIL="you@example.com"

# Enables AI replay review (Stage B). Without it, /api/reviews POST returns 501.
# ANTHROPIC_API_KEY="sk-ant-..."
